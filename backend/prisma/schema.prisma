generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url = env("DATABASE_URL")
}

// Enums ko MongoDB support karta hai Prisma 5+ mein
enum Role {
  SUPER_ADMIN
  CLIENT
  MANAGER
  SUPPORT
}

enum PaymentStatus {
  PAID
  UNPAID
  OVERDUE
}

enum ClientStatus {
  ACTIVE
  SUSPENDED
  EXPIRED
}

enum KbType {
  TEXT
  PDF
  DOCX
  URL
  FAQ
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  LOST
}

enum SenderType {
  AI
  LEAD
  MANUAL
}

enum OrderStatus {
  PENDING
  CONFIRMED
  CANCELED
}

model User {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  email String @unique
  password String
  role Role @default(CLIENT)
  clientId String? @db.ObjectId
  client Client? @relation(fields: [clientId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  twoFactorEnabled Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  auditLogs AuditLog[]
}

model Client {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  companyName String
  ownerName String
  email String @unique
  phoneNumber String?
  address String?
  
  // Subscription info
  subscriptionStartDate DateTime?
  subscriptionEndDate DateTime?
  subscriptionDays Int @default(0)
  amountCharged Float @default(0.0)
  paymentStatus PaymentStatus @default(UNPAID)
  status ClientStatus @default(ACTIVE)
  
  // Evolution API
  instanceName String?
  instanceId String?
  evolutionApiUrl String?
  evolutionApiKey String?
  n8nWebhookUrl String?
  
  // AI Config
  defaultAiModel String @default("gpt-4o-mini")
  defaultPrompt String?
  temperature Float @default(0.7)
  maxTokens Int @default(500)
  
  agentConfig AgentConfig?
  
  users User[]
  knowledgeBases KnowledgeBase[]
  leads Lead[]
  orders Order[]
  invoices Invoice[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model KnowledgeBase {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  clientId String @db.ObjectId
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title String
  type KbType
  content String? // @db.Text hata diya - MongoDB mein String already unlimited hai
  category String?
  fileType String?
  fileUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Lead {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  clientId String @db.ObjectId
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name String
  phoneNumber String
  email String?
  companyName String?
  interestedService String?
  summary String?
  potentialValue Float?
  source String?
  status LeadStatus @default(NEW)
  assignedDate DateTime?
  lastInteraction DateTime?
  botEnabled Boolean @default(true)
  
  messages Message[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clientId, phoneNumber])
}

model Message {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  leadId String @db.ObjectId
  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  sender SenderType
  content String
  createdAt DateTime @default(now())
}

model Invoice {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  clientId String @db.ObjectId
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  invoiceNumber String @unique
  amount Float
  paymentDate DateTime?
  renewalDate DateTime?
  paymentMethod String?
  notes String?
  createdAt DateTime @default(now())
}

model Order {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  clientId String @db.ObjectId
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name String
  phoneNumber String
  companyName String?
  products String // JSON string store kar sakte ho
  address String
  status OrderStatus @default(PENDING)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  userId String? @db.ObjectId
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  action String
  details String?
  ipAddress String?
  createdAt DateTime @default(now())
}

model AgentConfig {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  clientId String @unique @db.ObjectId
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  instanceName String?
  isActive Boolean @default(true)
  status String @default("ONLINE")
  scheduleEnabled Boolean @default(false)
  scheduleStartTime String? 
  scheduleEndTime String? 
  timezone String @default("UTC")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GlobalSetting {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  key String @unique
  value String
}