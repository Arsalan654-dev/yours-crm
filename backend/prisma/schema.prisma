generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  password       String
  role           Role      @default(CLIENT)
  clientId       String?   // Null if SUPER_ADMIN
  client         Client?   @relation(fields: [clientId], references: [id])
  twoFactorEnabled Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  auditLogs      AuditLog[]
}

enum Role {
  SUPER_ADMIN
  CLIENT
  MANAGER
  SUPPORT
}

model Client {
  id                    String    @id @default(uuid())
  companyName           String
  ownerName             String
  email                 String    @unique
  phoneNumber           String?
  address               String?
  
  // Subscription info
  subscriptionStartDate DateTime?
  subscriptionEndDate   DateTime?
  subscriptionDays      Int       @default(0)
  amountCharged         Float     @default(0.0)
  paymentStatus         PaymentStatus @default(UNPAID)
  status                ClientStatus  @default(ACTIVE)
  
  // Evolution API
  instanceName          String?
  instanceId            String?
  evolutionApiUrl       String?
  evolutionApiKey       String?
  n8nWebhookUrl         String?
  
  // AI Config
  defaultAiModel        String    @default("gpt-4o-mini")
  defaultPrompt         String?   @db.Text
  temperature           Float     @default(0.7)
  maxTokens             Int       @default(500)
  
  agentConfig           AgentConfig?
  
  users                 User[]
  knowledgeBases        KnowledgeBase[]
  leads                 Lead[]
  orders                Order[]
  invoices              Invoice[]
  
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

enum PaymentStatus {
  PAID
  UNPAID
  OVERDUE
}

enum ClientStatus {
  ACTIVE
  SUSPENDED
  EXPIRED
}

model KnowledgeBase {
  id          String   @id @default(uuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id])
  title       String
  type        KbType
  content     String?  @db.Text // Text content, or URL, or path to uploaded file
  category    String?
  fileType    String?
  fileUrl     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum KbType {
  TEXT
  PDF
  DOCX
  URL
  FAQ
}

model Lead {
  id                String       @id @default(uuid())
  clientId          String
  client            Client       @relation(fields: [clientId], references: [id])
  name              String
  phoneNumber       String
  email             String?
  companyName       String?
  interestedService String?
  summary           String?      @db.Text
  potentialValue    Float?
  source            String?
  status            LeadStatus   @default(NEW)
  assignedDate      DateTime?
  lastInteraction   DateTime?
  botEnabled        Boolean      @default(true) // Lead-specific bot kill switch
  
  messages          Message[]
  
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@unique([clientId, phoneNumber])
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  LOST
}

model Message {
  id          String   @id @default(uuid())
  leadId      String
  lead        Lead     @relation(fields: [leadId], references: [id])
  sender      SenderType
  content     String   @db.Text
  createdAt   DateTime @default(now())
}

enum SenderType {
  AI
  LEAD
  MANUAL
}

model Invoice {
  id             String   @id @default(uuid())
  clientId       String
  client         Client   @relation(fields: [clientId], references: [id])
  invoiceNumber  String   @unique
  amount         Float
  paymentDate    DateTime?
  renewalDate    DateTime?
  paymentMethod  String?
  notes          String?  @db.Text
  createdAt      DateTime @default(now())
}
model Order {
  id             String      @id @default(uuid())
  clientId       String
  client         Client      @relation(fields: [clientId], references: [id])
  name           String
  phoneNumber    String
  companyName    String?
  products       String      @db.Text
  address        String      @db.Text
  status         OrderStatus @default(PENDING)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

enum OrderStatus {
  PENDING
  CONFIRMED
  CANCELED
}
model AuditLog {
  id          String   @id @default(uuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  action      String
  details     String?  @db.Text
  ipAddress   String?
  createdAt   DateTime @default(now())
}

model AgentConfig {
  id                String   @id
  client            Client   @relation(fields: [id], references: [id], onDelete: Cascade)
  clientId          String?
  instanceName      String?
  isActive          Boolean  @default(true)
  status            String   @default("ONLINE")
  scheduleEnabled   Boolean  @default(false)
  scheduleStartTime String?  
  scheduleEndTime   String?  
  timezone          String   @default("UTC")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model GlobalSetting {
  id    String @id @default(uuid())
  key   String @unique
  value String @db.Text
}
